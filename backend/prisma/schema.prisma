generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Taxis {
  id          Int      @id @default(autoincrement())
  name        String
  phones      String[]
  time        String
  price       String
  class       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Articles {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  image     String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteConfig {
  id           Int      @id @default(autoincrement())
  aboutText    String   @db.Text
  bannerDesk   String
  bannerMobile String
  updatedAt    DateTime @updatedAt
}

model Contacts {
  id        Int      @id @default(autoincrement())
  email     String
  phone     String
  address   String?
  workHours String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        Int      @id @default(autoincrement())
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}